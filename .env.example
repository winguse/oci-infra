# Copy to .env and fill in before: make apply
CODER_DOMAIN=coder.level2.example.com
COMMON_TLS_WILDCARD_DOMAIN=*.level2.example.com
CODER_TLS_WILDCARD_DOMAIN=*.coder.level2.example.com
ACME_EMAIL=certs@example.com

# ACMEDNS server (cert-manager dns01 acmeDNS host)
# https://cert-manager.io/docs/configuration/acme/dns01/acme-dns/
# no tailing /
ACME_DNS_HOST=https://challenge.example.com

# PostgreSQL credentials (in-cluster Bitnami chart)
POSTGRES_USER=coder
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_DATABASE=coder

# OIDC (optional — omit CODER_OIDC_ISSUER_URL to use built-in email/password login)
# Redirect URI in your IdP: https://$CODER_DOMAIN/api/v2/users/oidc/callback
CODER_OIDC_ISSUER_URL=https://your-idp.example.com
CODER_OIDC_CLIENT_ID=
CODER_OIDC_CLIENT_SECRET=
CODER_OIDC_EMAIL_DOMAIN=example.com
# CODER_OIDC_IGNORE_EMAIL_VERIFIED=true
# CODER_DISABLE_PASSWORD_AUTH=true

# ACME DNS credentials for COMMON (cert-manager dns01 acmeDNS)
COMMON_ACME_DNS_DOMAIN=level2.example.com
COMMON_ACME_DNS_USERNAME=
COMMON_ACME_DNS_PASSWORD=
COMMON_ACME_DNS_FULLDOMAIN=<uuid>.level2.example.com
COMMON_ACME_DNS_SUBDOMAIN=<uuid>
COMMON_ACME_DNS_ALLOWFROM=10.42.0.0/16

# ACME DNS credentials for CODER (cert-manager dns01 acmeDNS)
CODER_ACME_DNS_DOMAIN=coder.level2.example.com
CODER_ACME_DNS_USERNAME=
CODER_ACME_DNS_PASSWORD=
CODER_ACME_DNS_FULLDOMAIN=<uuid>.coder.level2.example.com
CODER_ACME_DNS_SUBDOMAIN=<uuid>
CODER_ACME_DNS_ALLOWFROM=10.42.0.0/16

# OCI OKE Node Pool OCID for the Cluster Autoscaler
# Retrieve it via: pulumi stack output nodePoolId --cwd pulumi/oke
OKE_NODEPOOL_OCID=

# Cloudflare Tunnel configuration (when CLOUDFLARE_TUNNEL_TOKEN is set, it runs the sidecar)
CLOUDFLARE_TUNNEL_TOKEN=
CLOUDFLARE_CODER_DOMAIN=
CLOUDFLARE_CODER_TLS_WILDCARD_DOMAIN=
